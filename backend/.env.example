# Copy to .env and adjust if needed. .env is gitignored — never commit real secrets.
ENVIRONMENT=local
DEBUG=true

# Matches backend/docker-compose.yml's db service (host port 5433).
DATABASE_URL=postgresql+asyncpg://hevy:hevy@localhost:5433/hevy

# From Supabase Project Settings -> API (Project URL and anon/public key).
SUPABASE_URL=
SUPABASE_ANON_KEY=
